{
  "name": "acro-snap",
  "version": "0.1.0",
  "private": true,
  "description": "Windows multi-window acronym knowledge manager for CS and AI researchers.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "node scripts/dev-runner.cjs",
    "build": "tsc --noEmit && vite build",
    "dist": "npm run build && electron-builder --win --x64",
    "preview": "vite preview --host 127.0.0.1",
    "start": "electron ."
  },
  "build": {
    "appId": "com.acrosnap.app",
    "productName": "AcroSnap",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "katex": "^0.16.11",
    "lucide-react": "^0.468.0",
    "marked": "^15.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  }
}
